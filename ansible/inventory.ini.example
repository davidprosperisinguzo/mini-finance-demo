# Ansible Inventory Example
# Copy the [web] section of this file to inventory.ini and update with your EC2 public IP
# The inventory.ini file is generated/updated during deployment via:
#   sed -i "s/<public_ip>/<actual_public_ip>/" inventory.ini

[defaults]
# Global configuration for all groups

[web]
# Web server group - EC2 instance where Nginx and the Mini Finance app will run
# Replace <public_ip> with the actual EC2 public IP from: terraform output -raw instance_public_ip
<public_ip> ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_ed25519

# Example with actual IP (for reference):
# 54.123.45.67 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_ed25519

[web:vars]
# Variables for the web group
ansible_python_interpreter=/usr/bin/python3     # Python interpreter on EC2
ansible_connection=ssh                           # SSH connection type
ansible_port=22                                  # SSH port
