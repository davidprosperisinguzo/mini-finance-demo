# Terraform Variables Example
# Copy this file to terraform.tfvars and update with your values
# DO NOT commit terraform.tfvars to git (contains sensitive SSH key path)

# AWS Configuration
aws_region  = "eu-west-2"        # AWS region (change to your preferred region)
environment = "mini-finance"     # Environment name used for resource tagging

# Network Configuration
vpc_cidr               = "10.0.0.0/16"     # VPC CIDR block
public_subnet_cidr     = "10.0.1.0/24"     # Public subnet CIDR block
private_subnet_cidr    = "10.0.2.0/24"     # Private subnet CIDR block

# EC2 Configuration
instance_type      = "t3.micro"                    # Instance type (t3.micro eligible for free tier)
ssh_public_key_path = "~/.ssh/id_ed25519.pub"     # Path to your SSH public key
                                                   # Generate with: ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519

# Optional: Advanced Configuration
# Uncomment and modify to customize:

# availability_zone = "eu-west-2a"  # Specific AZ in your region
# tags = {
#   Environment = "development"
#   ManagedBy   = "Terraform"
#   Project     = "mini-finance"
# }
